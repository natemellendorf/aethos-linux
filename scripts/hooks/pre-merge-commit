#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

main_tip="$(git rev-parse --verify refs/heads/main 2>/dev/null || true)"
merge_heads_file="$(git rev-parse --git-path MERGE_HEAD)"

if [[ -z "${main_tip}" || ! -f "${merge_heads_file}" ]]; then
  exit 0
fi

run_tests="0"
while IFS= read -r merge_head; do
  if [[ "${merge_head}" == "${main_tip}" ]]; then
    run_tests="1"
    break
  fi
done <"${merge_heads_file}"

if [[ "${run_tests}" != "1" ]]; then
  printf '[git-hook:pre-merge-commit] merge does not include refs/heads/main tip; skipping test gate\n'
  exit 0
fi

printf '[git-hook:pre-merge-commit] merging main tip, running tests\n'
cargo test

printf '[git-hook:pre-merge-commit] running GUI+network e2e gate\n'
scripts/e2e/pre-merge-gate.sh
